# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   configured via the environment. In that case, comment these lines out.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, lock files should be committed to version control.
#   For libraries, you should not commit the lock file.
# Pipfile.lock

# poetry
#   Similar to Pipenv, see https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipenv, see https://pdm.fming.dev/#usage
.pdm.toml
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/fannheyward/coc-pyright
__pypackages__/

